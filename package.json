    "prisma:generate": "prisma generate"
  },
  "devDependencies": {
    "prisma": "^6.7.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "@prisma/client": "^6.19.3",
    "@supabase/supabase-js": "^2.49.4",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "pg": "^8.13.1"
  }
