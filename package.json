{
  "name": "college-mcp-server",
  "version": "1.0.0",
  "description": "Role-based college management MCP server using Postgres",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "build": "node src/scripts/build-check.js",
    "db:migrate": "node src/scripts/run-sql.js sql/schema.sql",
    "db:seed": "node src/scripts/run-sql.js sql/seed.sql",
